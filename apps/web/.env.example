# Credenciais do Supabase (públicas — chave anon, protegida por RLS).
# Em dev, copie os valores que o `yarn dlx supabase status` imprime para .env.local.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Service-role (SERVER-ONLY, nunca exposto ao client): a ingestão litúrgica (A2)
# escreve o cache (liturgical_day/lectionary) contornando a RLS. Em prod, secret no Worker.
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Fontes litúrgicas (opcionais — têm default). Trocáveis atrás do LiturgyProvider.
# LITCAL_API_URL=https://litcal.johnromanodorazio.com/api/dev
# LITURGY_API_URL=https://liturgia.up.railway.app/v2
