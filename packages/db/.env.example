# Copie para packages/db/.env (git-ignored). NUNCA comite valores reais.

# Connection string do Postgres do Supabase (Settings → Database → Connection string).
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[HOST]:5432/postgres

# Projeto Supabase (Settings → API). O service_role é secreto — só no servidor/seed.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Bootstrap do 1º admin no seed (opcional). Com e-mail + senha + service_role acima,
# o `db:seed` CRIA a conta no Auth (já confirmada) e a promove a admin. Só com o e-mail,
# apenas promove um usuário que já se cadastrou pelo app.
ASAFE_ADMIN_EMAIL=
ASAFE_ADMIN_NAME=
ASAFE_ADMIN_PASSWORD=
